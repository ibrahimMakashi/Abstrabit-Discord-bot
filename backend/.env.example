# =============================================================================
# Backend environment — copy to backend/.env for local dev
# For Render production: add these in Dashboard → Environment (not in git)
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Local: development | Production (Render): production
NODE_ENV=development

# Render sets PORT automatically — you can omit PORT on Render or leave default
PORT=5000

# Local: http://localhost:5173
# Production: your live frontend URL (exact origin, no trailing slash)
# Example: https://your-dashboard.vercel.app
FRONTEND_URL=http://localhost:5173

# Optional: extra browser origins allowed for API + Socket.io CORS (comma-separated).
# Use on Render when testing local frontend against production Discord webhooks:
# SOCKET_EXTRA_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SOCKET_EXTRA_ORIGINS=

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# MongoDB Atlas connection string (free M0 cluster)
# Atlas → Network Access must allow 0.0.0.0/0 for Render/Vercel cloud hosts
# Example: mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/discord-bot-dashboard

# -----------------------------------------------------------------------------
# Auth secrets (required — generate unique random strings, 32+ chars)
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=replace-with-a-strong-32-char-secret
JWT_REFRESH_SECRET=replace-with-a-strong-32-char-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CSRF_SECRET=replace-with-a-strong-csrf-secret

# Encrypts per-admin channel IDs and webhook URLs in MongoDB (required, 32+ chars)
ENCRYPTION_KEY=replace-with-a-strong-32-character-secret

# -----------------------------------------------------------------------------
# Cookies
# -----------------------------------------------------------------------------
# COOKIE_DOMAIN — leave EMPTY on Render + Vercel (different hostnames).
# Only set if frontend and API share a parent domain (e.g. .yourdomain.com).
COOKIE_DOMAIN=

# Local: false | Production: true (HTTPS required)
COOKIE_SECURE=false

# Local (same machine / proxy): lax
# Production (frontend on Vercel, API on Render): none  (requires COOKIE_SECURE=true)
COOKIE_SAME_SITE=lax

# -----------------------------------------------------------------------------
# Discord (required for bot + interactions)
# From https://discord.com/developers/applications → your app
# -----------------------------------------------------------------------------
# General → Public Key
DISCORD_PUBLIC_KEY=

# General → Application ID
DISCORD_APPLICATION_ID=

# Bot → Reset Token (keep secret — server only)
DISCORD_BOT_TOKEN=

# Interactions Endpoint URL (set in Discord portal, not in .env):
# https://YOUR-RENDER-SERVICE.onrender.com/api/interactions

# Channel IDs and mirror webhook are NOT here — each admin sets them in dashboard Settings.

# -----------------------------------------------------------------------------
# Optional — AI enrichment for /report
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# -----------------------------------------------------------------------------
# Optional — profile avatar uploads (Cloudinary free tier)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=discord-dashboard/avatars

# -----------------------------------------------------------------------------
# Logging and rate limits (defaults are fine)
# -----------------------------------------------------------------------------
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
INTERACTION_MAX_AGE_MS=300000

# =============================================================================
# PRODUCTION CHECKLIST (Render environment variables)
# =============================================================================
# NODE_ENV=production
# FRONTEND_URL=https://your-frontend.vercel.app
# MONGODB_URI=mongodb+srv://...
# JWT_ACCESS_SECRET=<your-secret>
# JWT_REFRESH_SECRET=<your-secret>
# CSRF_SECRET=<your-secret>
# ENCRYPTION_KEY=<your-secret>
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=none
# COOKIE_DOMAIN=          (leave empty)
# DISCORD_PUBLIC_KEY=...
# DISCORD_APPLICATION_ID=...
# DISCORD_BOT_TOKEN=...
# OPENAI_API_KEY=...      (optional)
# =============================================================================
