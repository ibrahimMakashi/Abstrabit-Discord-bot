# Backend environment (copy to backend/.env)

NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database — MongoDB Atlas free tier or local MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/discord-bot-dashboard

# Auth — generate long random strings (32+ characters)
JWT_ACCESS_SECRET=replace-with-a-strong-32-char-secret
JWT_REFRESH_SECRET=replace-with-a-strong-32-char-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CSRF_SECRET=replace-with-a-strong-csrf-secret

# Encrypts per-admin channel IDs and webhook URLs in the database
ENCRYPTION_KEY=replace-with-a-strong-32-character-secret

# Cookies
# COOKIE_DOMAIN — leave EMPTY for Vercel (frontend and backend on different *.vercel.app hosts).
# Only set if you use a custom shared parent domain (e.g. .yourdomain.com) for both apps.
COOKIE_DOMAIN=
COOKIE_SECURE=false
# Local development: lax | Production (separate frontend + backend URLs): none + COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

# Discord Developer Portal — Application → General / Bot
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=

# Optional — AI enrichment for /report (disable in Settings if omitted)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional — profile avatar uploads (dashboard works without these)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=discord-dashboard/avatars

# Logging and limits (defaults are fine for local dev)
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
INTERACTION_MAX_AGE_MS=300000
