# Frontend environment (copy to frontend/.env)

# Backend API URL (required for production when frontend and backend are on different hosts)
VITE_API_BASE_URL=https://abstrabit-discord-bot.vercel.app/api

# Optional — Socket.io origin. If omitted, derived from VITE_API_BASE_URL (strips /api).
# VITE_SOCKET_URL=https://abstrabit-discord-bot.vercel.app

# Local development — use either:
# VITE_API_BASE_URL=http://localhost:5000/api
# or leave unset and rely on Vite proxy (see vite.config.js) with baseURL /api
