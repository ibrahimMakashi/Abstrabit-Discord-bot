# =============================================================================
# Frontend environment — copy to frontend/.env
# For Vercel production: add in Project → Settings → Environment Variables
# =============================================================================

# Backend API URL
# Local (recommended — Vite proxy):  /api   or leave unset
# Local (direct to backend):         http://localhost:5000/api
# Production (Render API):           https://YOUR-RENDER-SERVICE.onrender.com/api
# VITE_API_BASE_URL=/api

# Socket.io origin (optional)
# Production example: https://YOUR-RENDER-SERVICE.onrender.com
#
# Local dev when Discord interactions hit production (shared MongoDB):
# 1) On Render, set SOCKET_EXTRA_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 2) Uncomment and set your Render URL below:
# VITE_SOCKET_URL=https://YOUR-RENDER-SERVICE.onrender.com
