# =============================================================================
# Frontend environment — copy to frontend/.env
# For Vercel production: add in Project → Settings → Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# RECOMMENDED — Local frontend + deployed Render backend
# -----------------------------------------------------------------------------
# Discord only sends slash commands to your public interactions URL on Render.
# A local backend (localhost:5000) does NOT receive Discord requests unless
# you use ngrok and change the interactions URL in the Developer Portal.
#
# Use this for normal local UI work (dashboard, settings, live updates):
VITE_API_BASE_URL=https://abstrabit-discord-bot.onrender.com/api
VITE_SOCKET_URL=https://abstrabit-discord-bot.onrender.com
#
# On Render, also set (Environment → backend service):
# SOCKET_EXTRA_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# FRONTEND_URL=https://your-frontend.vercel.app   (production frontend URL)

# -----------------------------------------------------------------------------
# Alternative — full local stack (backend + frontend on your machine)
# -----------------------------------------------------------------------------
# Requires ngrok + Discord interactions URL pointing at ngrok. See README.
# VITE_API_BASE_URL=/api
# VITE_SOCKET_URL is not needed (Vite proxies /socket.io to localhost:5000)

# -----------------------------------------------------------------------------
# Production (Vercel frontend)
# -----------------------------------------------------------------------------
# VITE_API_BASE_URL=https://abstrabit-discord-bot.onrender.com/api
# VITE_SOCKET_URL=https://abstrabit-discord-bot.onrender.com
